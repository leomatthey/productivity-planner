# ─── Stride backend environment ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp backend/.env.example backend/.env
#
# Only ANTHROPIC_API_KEY is required. The TZ value has a sensible default;
# Google Calendar is fully optional (see README for the OAuth setup).

# REQUIRED — Anthropic API key for the AI Assistant and Analytics Insights.
# Get one (free trial credit) at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# RECOMMENDED — IANA timezone for the user. Drives the agent's local-time
# rendering and the smart scheduler's work-hour conversion. Example values:
#   Europe/Madrid · Europe/Berlin · America/New_York · America/Los_Angeles
TZ=Europe/Madrid

# OPTIONAL — Override the SQLite database path inside the container.
# Default keeps it inside the bind-mounted ./backend/data/ directory.
# DB_PATH=./data/planner.db

# OPTIONAL — Google Calendar integration.
# The app works fully without this. If you want to sync your real Google
# events, follow the README's "Google Calendar (optional)" section to obtain
# a client_secrets.json from Google Cloud Console and place it at:
#   backend/data/google_client_secrets.json
# No env var to set — the file's presence is what enables the flow.
