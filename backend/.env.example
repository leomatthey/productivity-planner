# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Anthropic API key for AI Assistant and Analytics Insights
# Get a free key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: custom path for the SQLite database (default: ./data/planner.db)
# DB_PATH=./data/planner.db

# Optional: Google Calendar integration
# Requires google_client_secrets.json in backend/data/
# See README for setup instructions
